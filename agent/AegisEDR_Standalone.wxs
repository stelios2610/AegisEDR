<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package
    Name="AegisEDR"
    Manufacturer="AegisEDR Security"
    Version="2.0.0.0"
    UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EFABCDEF1234"
    Language="1033"
    Compressed="yes"
    Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of AegisEDR is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="MainFeature" Title="AegisEDR" Level="1">
      <ComponentGroupRef Id="AgentComponents" />
      <ComponentGroupRef Id="YaraRulesComponents" />
      <ComponentRef Id="AgentTaskComp" />
      <ComponentRef Id="TrayTaskComp" />
      <ComponentRef Id="ShortcutComp" />
    </Feature>

  </Package>

  <!-- ── Install directory ── -->
  <Fragment>
    <StandardDirectory Id="ProgramFilesFolder">
      <Directory Id="INSTALLFOLDER" Name="AegisEDR" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppMenuFolder" Name="AegisEDR" />
    </StandardDirectory>
    <StandardDirectory Id="DesktopFolder" />
  </Fragment>

  <!-- ── Main executables ── -->
  <Fragment>
    <ComponentGroup Id="AgentComponents" Directory="INSTALLFOLDER">

      <Component Id="AgentExeComp" Guid="B1C2D3E4-F5A6-7890-BCDE-FABCDEF12345">
        <File Id="AgentExe" Name="AegisEDR-Agent.exe"
              Source="!(bind.path.DistDir)\AegisEDR-Agent.exe"
              KeyPath="yes" />
      </Component>

      <Component Id="AppExeComp" Guid="C2D3E4F5-A6B7-8901-CDEF-ABCDEF123456">
        <File Id="AppExe" Name="AegisEDR.exe"
              Source="!(bind.path.DistDir)\AegisEDR.exe"
              KeyPath="yes" />
      </Component>

      <Component Id="TrayExeComp" Guid="D3E4F5A6-B7C8-9012-DEFA-BCDEF1234567">
        <File Id="TrayExe" Name="AegisEDR-Tray.exe"
              Source="!(bind.path.DistDir)\AegisEDR-Tray.exe"
              KeyPath="yes" />
      </Component>

    </ComponentGroup>
  </Fragment>

  <!-- ── YARA rules ── -->
  <Fragment>
    <DirectoryRef Id="INSTALLFOLDER">
      <Directory Id="YaraRulesDir" Name="yara_rules" />
    </DirectoryRef>

    <ComponentGroup Id="YaraRulesComponents" Directory="YaraRulesDir">
      <Component Id="RansomwareRulesComp" Guid="E4F5A6B7-C8D9-0123-EFAB-CDEF12345678">
        <File Id="RansomwareYar" Name="ransomware.yar"
              Source="!(bind.path.YaraRulesDir)\ransomware.yar" KeyPath="yes" />
      </Component>
      <Component Id="SpywareRulesComp" Guid="F5A6B7C8-D9E0-1234-FABC-DEF123456789">
        <File Id="SpywareYar" Name="spyware.yar"
              Source="!(bind.path.YaraRulesDir)\spyware.yar" KeyPath="yes" />
      </Component>
      <Component Id="MalwareRulesComp" Guid="A6B7C8D9-E0F1-2345-ABCD-EF1234567890">
        <File Id="MalwareYar" Name="malware.yar"
              Source="!(bind.path.YaraRulesDir)\malware.yar" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!-- ── Scheduled tasks (via Registry) ── -->
  <Fragment>
    <DirectoryRef Id="INSTALLFOLDER">

      <!-- Agent task: runs at startup as SYSTEM -->
      <Component Id="AgentTaskComp" Guid="B7C8D9E0-F1A2-3456-BCDE-F12345678901">
        <RegistryValue Root="HKLM" Key="SOFTWARE\AegisEDR" Name="AgentPath"
                       Type="string" Value="[INSTALLFOLDER]AegisEDR-Agent.exe" KeyPath="yes" />
        <util:XmlFile xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util" />
      </Component>

      <!-- Tray: runs at logon for current user -->
      <Component Id="TrayTaskComp" Guid="C8D9E0F1-A2B3-4567-CDEF-012345678901">
        <RegistryValue Root="HKLM" Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Run"
                       Name="AegisEDRTray"
                       Type="string" Value="&quot;[INSTALLFOLDER]AegisEDR-Tray.exe&quot;"
                       KeyPath="yes" />
      </Component>

    </DirectoryRef>
  </Fragment>

  <!-- ── Desktop shortcut ── -->
  <Fragment>
    <DirectoryRef Id="DesktopFolder">
      <Component Id="ShortcutComp" Guid="D9E0F1A2-B3C4-5678-DEFA-123456789012">
        <Shortcut Id="DesktopShortcut"
                  Name="AegisEDR"
                  Description="AegisEDR Security Dashboard"
                  Target="[INSTALLFOLDER]AegisEDR.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU" Key="SOFTWARE\AegisEDR" Name="Installed"
                       Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>
  </Fragment>

</Wix>
